  opportunityMatrix Json?    @map("opportunity_matrix") // { ERP: 'High', CRM: 'High', Accounting: 'Low' }
  generatedAt       DateTime @default(now()) @map("generated_at")

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("ai_recommendations")
}

// ==========================================
// 16. REPORTS & EXPORTS LOGS
// ==========================================

model SavedReport {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  reportType  String   @map("report_type") // BusinessAnalysis, SWOT, Competitor, Financial etc.
  format      String   // PDF, Excel, PowerPoint
  generatedAt DateTime @default(now()) @map("generated_at")
  downloadUrl String   @map("download_url")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("saved_reports")
}

// ==========================================
// EXISTING MODELS (Maintained and Integrated)
// ==========================================

model Contact {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  name            String
  designation     String
  email           String
  phone           String
  isDecisionMaker Boolean  @map("is_decision_maker")

  department      String?
  linkedin        String?
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunities      Opportunity[]
  campaignRecipients CampaignRecipient[]

  @@index([companyId])
  @@map("contacts")
}

model JobPosting {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  jobTitle         String   @map("job_title")
  platform         String
  postedDate       DateTime @map("posted_date")
  hiringSignalType String   @map("hiring_signal_type")

  // Advanced Hiring Intelligence Fields
  salaryRange      String?  @map("salary_range")
  skillDemand      String[] @map("skill_demand")
  department       String?
  isRemote         Boolean  @default(false) @map("is_remote")

  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("job_postings")
}

model LeadScore {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  aiScore      Int      @map("ai_score")
  scoreReasons String[] @map("score_reasons") // e.g., Recently hiring, Revenue growing, New office
  scoredAt     DateTime @default(now()) @map("scored_at")

  isHotLead   Boolean  @default(false) @map("is_hot_lead")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("lead_scores")
}

model PipelineHistory {
  id        String        @id @default(uuid()) @db.Uuid
  companyId String        @map("company_id") @db.Uuid
  fromStage PipelineStage @map("from_stage")
  toStage   PipelineStage @map("to_stage")
  changedAt DateTime      @default(now()) @map("changed_at")
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("pipeline_histories")
}

model JobApplication {
  id               String        @id @default(uuid()) @db.Uuid
  companyId        String        @map("company_id") @db.Uuid
  ownerId          String?       @map("owner_id") @db.Uuid
  jobTitle         String        @map("job_title")
  position         String?
  department       String?
  experience       String?
  salary           String?
  location         String?
  workMode         String?       @map("work_mode")
  jobType          String?       @map("job_type")
  datePosted       DateTime?     @map("date_posted")
  deadline         DateTime?
  applyMethod      String?       @map("apply_method")
  applyEmail       String?       @map("apply_email")
  applyLink        String?       @map("apply_link")
  jobLink          String?       @map("job_link")
  description      String?
  requirements     String?
  benefits         String?
  status           ApplicationStatus @default(Draft)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner            User?         @relation(fields: [ownerId], references: [id])
  histories        JobHistory[]
  documents        Document[]
  followups        Followup[]

  @@index([companyId])
  @@index([ownerId])
  @@map("job_applications")
}

model Networking {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  platform         String?
  profileUrl       String?   @map("profile_url")
  connectionStatus String?   @map("connection_status")
  connectedDate    DateTime? @map("connected_date")
  lastMessage      String?   @map("last_message")
  nextFollowup     DateTime? @map("next_followup")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("networking")
}

model JobHistory {
  id               String         @id @default(uuid()) @db.Uuid
  jobApplicationId String         @map("job_application_id") @db.Uuid
  status           String
  remarks          String?
  updatedBy        String?        @map("updated_by")
  updatedAt        DateTime       @default(now()) @map("updated_at")

  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([jobApplicationId])
  @@map("job_histories")
}

model Document {
  id               String         @id @default(uuid()) @db.Uuid
  jobApplicationId String         @map("job_application_id") @db.Uuid
  resume           String?
  coverLetter      String?        @map("cover_letter")
  proposal         String?
  portfolio        String?
  other            String?

  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([jobApplicationId])
  @@map("documents")
}

model Followup {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  note             String
  followUpDate     DateTime        @map("follow_up_date")
  status           FollowupStatus  @default(Pending)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  companyId        String?         @map("company_id") @db.Uuid
  jobApplicationId String?         @map("job_application_id") @db.Uuid

  company          Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([jobApplicationId])
  @@index([userId])
  @@map("followups")
}

model CaptureLog {
  id             String         @id @default(uuid()) @db.Uuid
  companyId      String         @map("company_id") @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  sourceId       String         @map("source_id") @db.Uuid
  capturedAt     DateTime       @default(now()) @map("captured_at")
  rawDataUrl     String         @map("raw_data_url")
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePlatform SourcePlatform @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@map("capture_logs")
}

model SourcePlatform {
  id           String       @id @default(uuid()) @db.Uuid
  platformName String       @map("platform_name")
  platformType String       @map("platform_type")
  captureLogs  CaptureLog[]

  @@map("source_platforms")
}

model WeeklyReport {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  weekStart      DateTime @map("week_start")
  leadsCaptured  Int      @map("leads_captured")
  leadsQualified Int      @map("leads_qualified")
  followupsDone  Int      @map("followups_done")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("weekly_reports")
}

model Deal {
  id            String    @id @default(uuid()) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  title         String
  value         Decimal   @db.Decimal(12,2)
  currency      String    @default("USD")
  stage         DealStage @default(Discovery)
  probability   Int       @default(10)
  expectedClose DateTime? @map("expected_close")
  assignedTo    String    @map("assigned_to") @db.Uuid
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee      User          @relation(fields: [assignedTo], references: [id])
  activities    CrmActivity[]

  @@index([companyId])
  @@index([assignedTo])
  @@index([stage])
  @@map("deals")
}

model Opportunity {
  id              String            @id @default(uuid()) @db.Uuid
  companyId       String            @map("company_id") @db.Uuid
  contactId       String?           @map("contact_id") @db.Uuid
  title           String
  description     String?
  expectedRevenue Decimal           @db.Decimal(12,2) @map("expected_revenue")
  probability     Int               @default(50)
  status          OpportunityStatus @default(Open)
  source          String?
  closeDate       DateTime?         @map("close_date")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact         Contact?  @relation(fields: [contactId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@map("opportunities")
}

model EmailCampaign {
  id           String              @id @default(uuid()) @db.Uuid
  name         String
  subject      String
  body         String
  status       CampaignStatus      @default(Draft)
  sentAt       DateTime?           @map("sent_at")
  totalSent    Int                 @default(0) @map("total_sent")
  totalOpened  Int                 @default(0) @map("total_opened")
  totalClicked Int                 @default(0) @map("total_clicked")
  createdBy    String              @map("created_by") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at")

  creator      User                @relation(fields: [createdBy], references: [id])
  recipients   CampaignRecipient[]

  @@index([createdBy])
  @@map("email_campaigns")
}

model CampaignRecipient {
  id         String           @id @default(uuid()) @db.Uuid
  campaignId String           @map("campaign_id") @db.Uuid
  contactId  String           @map("contact_id") @db.Uuid
  status     RecipientStatus  @default(Pending)
  sentAt     DateTime?        @map("sent_at")
  openedAt   DateTime?        @map("opened_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact       @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([contactId])
  @@map("campaign_recipients")
}

model CrmTask {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String?
  type        String       @default("Task")
  priority    TaskPriority @default(Medium)
  status      TaskStatus   @default(Pending)
  dueDate     DateTime?    @map("due_date")
  assignedTo  String       @map("assigned_to") @db.Uuid
  companyId   String?      @map("company_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  assignee    User      @relation(fields: [assignedTo], references: [id])
  company     Company?  @relation(fields: [companyId], references: [id])

  @@index([assignedTo])
  @@index([companyId])
  @@index([status])
  @@map("crm_tasks")
}

model CrmActivity {
  id          String   @id @default(uuid()) @db.Uuid
  type        String
  title       String
  description String?
  companyId   String?  @map("company_id") @db.Uuid
  dealId      String?  @map("deal_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company? @relation(fields: [companyId], references: [id])
  deal        Deal?    @relation(fields: [dealId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([dealId])
  @@index([userId])
  @@map("crm_activities")
}
