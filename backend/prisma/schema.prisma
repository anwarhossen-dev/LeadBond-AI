model SwotAnalysis {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @unique @map("company_id") @db.Uuid
  strengths     String[] // Array representation of bullet points
  weaknesses    String[]
  opportunities String[]
  threats       String[]
  updatedAt     DateTime @updatedAt @map("updated_at")

