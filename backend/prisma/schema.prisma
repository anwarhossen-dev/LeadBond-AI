  burnRate      Decimal? @db.Decimal(15,2) @map("burn_rate")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("financial_intelligence")
}

// ==========================================
// 11. TECHNOLOGY STACK ANALYSIS
// ==========================================

model TechnologyAnalysis {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @unique @map("company_id") @db.Uuid
  languages     String[] // PHP, Node.js etc.
