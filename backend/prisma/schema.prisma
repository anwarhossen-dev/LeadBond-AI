  companyId         String   @unique @map("company_id") @db.Uuid
  targetAudience    String   @map("target_audience")
  customerSegment   String   @map("customer_segment")
  primaryCountry    String   @map("primary_country")
  genderDemographic String?  @map("gender_demographic")
  ageGroup          String?  @map("age_group")
  incomeLevel       String?  @map("income_level")
  buyingBehavior    String?  @map("buying_behavior")
  engagementScore   Int      @map("engagement_score")
  churnRate         Float    @map("churn_rate")
  predictedChurnRate Float?  @map("predicted_churn_rate") // AI Churn Prediction
  loyaltyScore      Int      @map("loyalty_score")

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("customer_analyses")
}

// ==========================================
