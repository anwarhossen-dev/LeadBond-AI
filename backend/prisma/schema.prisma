// ==========================================
// 15. AI RECOMMENDATION ENGINE & OPPORTUNITIES
// ==========================================

model AiRecommendation {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  hiringGrowthPulse String?  @map("hiring_growth_pulse") // e.g., "Increased hiring by 42%"
  revenueGrowthPulse String? @map("revenue_growth_pulse") // e.g., "Estimated to grow 25%"
  suitableSolution  String   @map("suitable_solution") // e.g., Enterprise CRM
  recommendedProduct String  @map("recommended_product") // e.g., LeadBond HRMS
  nextBestAction    String?  @map("next_best_action") // AI Next Best Action
