  @@map("swot_analyses")
}

// ==========================================
// 10. FINANCIAL INTELLIGENCE
// ==========================================

model FinancialIntelligence {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @unique @map("company_id") @db.Uuid
  revenue       Decimal  @db.Decimal(15,2)
  profit        Decimal  @db.Decimal(15,2)
  expenses      Decimal  @db.Decimal(15,2)
  ebitda        Decimal  @db.Decimal(15,2)
  cashFlow      Decimal  @db.Decimal(15,2) @map("cash_flow")
  fundingTotal  Decimal  @default(0.0) @db.Decimal(15,2) @map("funding_total")
