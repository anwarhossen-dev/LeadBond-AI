// ==========================================
// 14. RISK MATRIX
// ==========================================

model RiskAnalysis {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @unique @map("company_id") @db.Uuid
  bankruptcyRisk  RiskLevel @default(Low) @map("bankruptcy_risk")
  financialRisk   RiskLevel @default(Low) @map("financial_risk")
  hiringRisk      RiskLevel @default(Low) @map("hiring_risk")
  complianceRisk  RiskLevel @default(Low) @map("compliance_risk")
